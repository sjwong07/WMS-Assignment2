
@section Styles {
    <link rel="stylesheet" href="~/css/menu.css" />
}

<div class="row">
    <div class="col-md-8">
        <h2><i class="fas fa-plus-circle"></i> Create New Order</h2>
        <hr />
    </div>
</div>

<div class="row">
    <!-- Menu Items Selection -->
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-book"></i> Select Menu Items</h5>
            </div>
            <div class="card-body" style="max-height: 500px; overflow-y: auto;">
                <div class="row g-3">
                    
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
         

    <!-- Order Summary -->
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0"><i class="fas fa-shopping-cart"></i> Order Summary</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="TableId" class="form-label"></label>
                        <select asp-for="TableId" asp-items="Model.Tables" class="form-select">
                            <option value="">-- Select Table --</option>
                        </select>
                        <span asp-validation-for="TableId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SpecialInstructions" class="form-label"></label>
                        <textarea asp-for="SpecialInstructions" class="form-control" rows="2"
                                  placeholder="Special requests..."></textarea>
                    </div>

                    <hr />

                    <div id="order-items-list">
                        <h6>Order Items</h6>
                        <div id="order-items-container">
                            <p class="text-muted text-center">No items added yet</p>
                        </div>
                    </div>

                    <hr />

                    <div class="d-flex justify-content-between">
                        <span>Subtotal:</span>
                        <span id="subtotal">RM 0.00</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Tax (6%):</span>
                        <span id="tax">RM 0.00</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Service Charge (10%):</span>
                        <span id="service-charge">RM 0.00</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between fw-bold">
                        <span>Total:</span>
                        <span id="total">RM 0.00</span>
                    </div>

                    <div class="d-grid gap-2 mt-3">
                        <button type="submit" class="btn btn-success" id="place-order-btn" disabled>
                            <i class="fas fa-check"></i> Place Order
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>


<!-- Hidden inputs for order items -->
<div id="order-items-data" style="display: none;">
    @for (int i = 0; i < Model.OrderItems.Count; i++)
    {
        <input type="hidden" name="OrderItems[@i].MenuItemId" value="@Model.OrderItems[i].MenuItemId" />
        <input type="hidden" name="OrderItems[@i].Quantity" value="@Model.OrderItems[i].Quantity" />
        <input type="hidden" name="OrderItems[@i].SpecialInstructions" value="@Model.OrderItems[i].SpecialInstructions" />
    }
</div>

@section Scripts {
    <script src="~/js/order.js"></script>
    @await Html.PartialAsync("_ValidationScriptsPartial")
}