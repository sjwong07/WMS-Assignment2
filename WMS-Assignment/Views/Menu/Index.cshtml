

@{
    ViewData["Title"] = "Menu";
}

<div class="row mb-4">
    <div class="col">
        <h1><i class="fas fa-book"></i> Our Menu</h1>
        <p class="text-muted">Explore our delicious selections</p>
    </div>
</div>

<!-- Categories Filter -->
<div class="row mb-4">
    <div class="col">
        <div class="btn-group" role="group">
            <a asp-action="Index" class="btn @(ViewBag.SelectedCategory == null ? "btn-primary" : "btn-outline-primary")">
                All
            </a>
            @foreach (var category in ViewBag.Categories)
            {
                <a asp-action="Index" asp-route-categoryId="@category.CategoryId"
                   class="btn @(ViewBag.SelectedCategory == category.CategoryId ? "btn-primary" : "btn-outline-primary")">
                    @category.CategoryName
                </a>
            }
        </div>
    </div>
</div>

<!-- Search -->
<div class="row mb-4">
    <div class="col-md-6">
        <form asp-action="Index" method="get" class="d-flex">
            <input type="text" name="searchTerm" class="form-control me-2" placeholder="Search menu..."
                   value="@ViewBag.SearchTerm" />
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-search"></i> Search
            </button>
        </form>
    </div>
</div>

<!-- Menu Items Grid -->
<div class="row">
    @if (Model.Any())
    {
        @foreach (var item in Model)
        {
            <div class="col-md-4 col-lg-3 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <i class="fas fa-utensils fa-3x text-primary mb-2"></i>
                        <h5 class="card-title">@item.Name</h5>
                        <p class="card-text text-muted small">@(item.Description?.Length > 100 ? item.Description.Substring(0, 100) + "..." : item.Description)</p>
                        <p class="card-text">
                            <span class="badge bg-success">@item.Category?.CategoryName</span>
                            @if (item.IsVegetarian)
                            {
                                <span class="badge bg-info">Vegetarian</span>
                            }
                            @if (item.IsSpicy)
                            {
                                <span class="badge bg-danger">Spicy</span>
                            }
                        </p>
                        <p class="card-text">
                            <span class="h5 text-primary">RM @item.Price.ToString("F2")</span>
                        </p>
                        <a asp-action="Details" asp-route-id="@item.MenuItemId" class="btn btn-outline-primary btn-sm w-100">
                            <i class="fas fa-eye"></i> View Details
                        </a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col text-center py-5">
            <i class="fas fa-search fa-3x text-muted mb-3"></i>
            <h3>No menu items found</h3>
            <p class="text-muted">Try adjusting your search or filter criteria</p>
        </div>
    }
</div>